{
  "name": "@row-chat/sqlite-db",
  "version": "1.0.1",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./prisma/generated/client/index.js",
    "./edge": "./prisma/generated/client/edge.js"
  },
  "scripts": {
    "prisma:tmpdb": "node --experimental-transform-types scripts/tmp-db.ts",
    "prisma:pull:bare": "npm run prisma:tmpdb && npx prisma db pull --force --url file:tmp/.tmp.db && rm -f tmp/.tmp.db tmp/.tmp.db-shm tmp/.tmp.db-wal",
    "prisma:case": "prisma-case-format -f prisma/schema.prisma",
    "prisma:repl": "node --experimental-transform-types scripts/generate-repl-types.ts",
    "prisma:pull": "npm run prisma:pull:bare && npm run prisma:case && npm run prisma:repl && npx prisma generate",
    "test": "node --experimental-transform-types --test 'test/**/*.test.ts'"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0"
  },
  "devDependencies": {
    "@row-chat/prisma-sqlite-wasm-adapter": "*",
    "@sqlite.org/sqlite-wasm": "^3.53.0-build1",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.9.0",
    "prisma": "^7.8.0",
    "prisma-case-format": "^2.2.1",
    "wa-sqlite": "^1.0.0"
  }
}
